:root{--blue:#2563EB;--blue-dark:#1d4ed8;--blue-light:#3b82f6;--blue-pale:#eff6ff;--dark:#111827;--text:#111827;--text2:#4b5563;--text3:#9ca3af;--border:#e5e7eb;--white:#ffffff;--radius:16px;}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Sora',sans-serif;color:var(--text);background:var(--white);overflow-x:hidden;}
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:0 6%;height:68px;background:rgba(255,255,255,0.94);backdrop-filter:blur(14px);border-bottom:1px solid rgba(229,231,235,0.8);}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none;}
.nav-logo-icon{width:36px;height:36px;background:var(--blue);border-radius:9px;display:flex;align-items:center;justify-content:center;}
.nav-logo-text{font-size:19px;font-weight:700;color:var(--dark);letter-spacing:-.5px;}
.nav-links{display:flex;align-items:center;gap:32px;}
.nav-links a{font-size:14px;font-weight:500;color:var(--text2);text-decoration:none;transition:color .2s;}
.nav-links a:hover{color:var(--blue);}
.btn-login{padding:9px 22px;border-radius:9px;font-size:14px;font-weight:600;color:white;background:var(--blue);border:none;cursor:pointer;text-decoration:none;transition:all .2s;font-family:'Sora',sans-serif;box-shadow:0 2px 12px rgba(37,99,235,.25);}
.btn-login:hover{background:var(--blue-dark);transform:translateY(-1px);}
.hero{padding:148px 6% 100px;display:flex;flex-direction:column;align-items:center;text-align:center;background:linear-gradient(180deg,#f0f7ff 0%,#ffffff 65%);position:relative;overflow:hidden;}
.hero::before{content:'';position:absolute;top:-200px;left:50%;transform:translateX(-50%);width:900px;height:900px;background:radial-gradient(circle,rgba(37,99,235,.07) 0%,transparent 70%);pointer-events:none;}
.hero-badge{display:inline-flex;align-items:center;gap:7px;background:var(--blue-pale);border:1px solid rgba(37,99,235,.2);color:var(--blue);font-size:13px;font-weight:600;padding:5px 16px;border-radius:100px;margin-bottom:28px;animation:fadeUp .5s ease both;}
.hero-badge-dot{width:6px;height:6px;background:var(--blue);border-radius:50%;}
.hero h1{font-size:clamp(38px,6vw,70px);font-weight:800;line-height:1.07;letter-spacing:-2px;color:var(--dark);max-width:820px;margin-bottom:22px;animation:fadeUp .55s .08s ease both;}
.hero h1 em{color:var(--blue);font-style:normal;}
.hero p{font-size:clamp(15px,1.8vw,19px);color:var(--text2);max-width:520px;line-height:1.7;font-weight:400;margin-bottom:38px;animation:fadeUp .55s .16s ease both;}
.hero-btn{padding:15px 36px;border-radius:11px;font-size:15px;font-weight:700;color:white;background:#25d366;border:none;cursor:pointer;text-decoration:none;transition:all .25s;font-family:'Sora',sans-serif;display:inline-flex;align-items:center;gap:9px;box-shadow:0 6px 24px rgba(37,211,102,.38);animation:fadeUp .55s .24s ease both;}
.hero-btn:hover{background:#1ebe5d;transform:translateY(-3px);box-shadow:0 10px 32px rgba(37,211,102,.45);}
.hero-preview{margin-top:64px;width:100%;max-width:860px;border-radius:20px;overflow:hidden;box-shadow:0 32px 80px rgba(0,0,0,.13),0 0 0 1px rgba(0,0,0,.06);animation:fadeUp .6s .32s ease both;}
.preview-bar{background:#f9fafb;border-bottom:1px solid var(--border);padding:11px 16px;display:flex;align-items:center;gap:7px;}
.dot{width:10px;height:10px;border-radius:50%;}
.dr{background:#ef4444;}.dy{background:#f59e0b;}.dg{background:#10b981;}
.preview-url{margin:0 auto;background:white;border:1px solid var(--border);border-radius:6px;padding:3px 14px;font-size:11px;color:var(--text3);font-family:'DM Mono',monospace;}
.preview-body{background:#f1f5f9;display:grid;grid-template-columns:200px 1fr;min-height:330px;}
.p-sidebar{background:#111827;padding:18px 14px;display:flex;flex-direction:column;gap:3px;}
.p-logo{display:flex;align-items:center;gap:8px;margin-bottom:18px;padding-bottom:14px;border-bottom:1px solid rgba(255,255,255,.07);}
.p-logo-icon{width:26px;height:26px;background:var(--blue);border-radius:6px;display:flex;align-items:center;justify-content:center;}
.p-logo-text{font-size:13px;font-weight:700;color:white;}
.p-nav{padding:7px 10px;border-radius:7px;font-size:12px;font-weight:500;color:rgba(255,255,255,.45);display:flex;align-items:center;gap:7px;}
.p-nav.on{background:rgba(37,99,235,.18);color:white;}
.p-dot{width:5px;height:5px;border-radius:50%;background:currentColor;flex-shrink:0;}
.p-main{padding:20px;display:flex;flex-direction:column;gap:14px;}
.p-greeting{font-size:14px;font-weight:700;color:var(--dark);}
.p-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
.p-stat{background:white;border-radius:10px;padding:13px 14px;border:1px solid var(--border);}
.p-stat-val{font-size:22px;font-weight:800;color:var(--dark);line-height:1;}
.p-stat-lbl{font-size:11px;color:var(--text3);margin-top:4px;}
.p-card{background:white;border-radius:10px;border:1px solid var(--border);overflow:hidden;}
.p-card-head{padding:11px 14px;font-size:12px;font-weight:700;border-bottom:1px solid var(--border);color:var(--dark);}
.p-cita{padding:10px 14px;display:flex;align-items:center;gap:10px;border-bottom:1px solid #f8fafc;}
.p-cita:last-child{border-bottom:none;}
.p-av{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:white;flex-shrink:0;}
.p-info{flex:1;min-width:0;}
.p-name{font-size:12px;font-weight:600;color:var(--dark);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.p-sub{font-size:11px;color:var(--text3);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.p-badge{padding:3px 9px;border-radius:100px;font-size:10px;font-weight:600;white-space:nowrap;flex-shrink:0;}
.bg{background:#d1fae5;color:#065f46;}.bb{background:#dbeafe;color:#1e40af;}.by{background:#fef3c7;color:#92400e;}
.logos{padding:36px 6%;border-top:1px solid var(--border);border-bottom:1px solid var(--border);display:flex;flex-direction:column;align-items:center;gap:18px;}
.logos-lbl{font-size:13px;color:var(--text3);font-weight:500;}
.logos-row{display:flex;gap:36px;align-items:center;flex-wrap:wrap;justify-content:center;}
.logo-pill{font-size:13px;font-weight:700;color:var(--text3);display:flex;align-items:center;gap:7px;}
.section{padding:96px 6%;}
.section-inner{max-width:1160px;margin:0 auto;}
.s-label{font-size:12px;font-weight:700;color:var(--blue);letter-spacing:1.2px;text-transform:uppercase;margin-bottom:10px;display:block;}
.s-title{font-size:clamp(26px,3.8vw,42px);font-weight:800;letter-spacing:-1.5px;color:var(--dark);line-height:1.1;max-width:540px;margin-bottom:14px;}
.s-sub{font-size:16px;color:var(--text2);max-width:460px;line-height:1.72;}
.feat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:18px;margin-top:52px;}
.feat{background:white;border:1.5px solid var(--border);border-radius:14px;padding:26px;transition:all .22s;}
.feat:hover{border-color:var(--blue);transform:translateY(-4px);box-shadow:0 14px 36px rgba(37,99,235,.1);}
.feat-icon{width:42px;height:42px;border-radius:10px;background:var(--blue-pale);display:flex;align-items:center;justify-content:center;font-size:19px;margin-bottom:14px;}
.feat-title{font-size:15px;font-weight:700;color:var(--dark);margin-bottom:7px;}
.feat-desc{font-size:13px;color:var(--text2);line-height:1.65;}
.how{padding:96px 6%;background:var(--dark);}
.how .s-label{color:var(--blue-light);}
.how .s-title{color:white;}
.how .s-sub{color:rgba(255,255,255,.55);}
.steps{display:grid;grid-template-columns:repeat(4,1fr);gap:0;margin-top:52px;position:relative;}
.steps::before{content:'';position:absolute;top:21px;left:12%;right:12%;height:1px;background:rgba(255,255,255,.08);}
.step{text-align:center;padding:0 16px;}
.step-n{width:42px;height:42px;border-radius:50%;background:var(--blue);display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:800;color:white;margin:0 auto 18px;position:relative;z-index:1;}
.step-title{font-size:14px;font-weight:700;color:white;margin-bottom:7px;}
.step-desc{font-size:12px;color:rgba(255,255,255,.45);line-height:1.6;}
.pricing{padding:96px 6%;background:var(--blue-pale);}
.p-card-wrap{max-width:460px;margin:52px auto 0;background:white;border-radius:22px;overflow:hidden;box-shadow:0 20px 60px rgba(37,99,235,.14);border:2px solid var(--blue);}
.p-head{background:var(--blue);padding:34px 38px;display:flex;align-items:flex-start;justify-content:space-between;}
.p-plan{font-size:12px;font-weight:700;color:rgba(255,255,255,.65);letter-spacing:1px;text-transform:uppercase;margin-bottom:5px;}
.p-price{font-size:52px;font-weight:800;color:white;letter-spacing:-2px;line-height:1;}
.p-price sup{font-size:24px;vertical-align:super;font-weight:700;}
.p-period{font-size:13px;color:rgba(255,255,255,.55);margin-top:5px;}
.p-badge-wrap{background:rgba(255,255,255,.13);border:1px solid rgba(255,255,255,.25);color:white;font-size:12px;font-weight:700;padding:8px 14px;border-radius:8px;text-align:center;line-height:1.4;}
.p-body{padding:34px 38px;}
.p-feats{list-style:none;display:flex;flex-direction:column;gap:13px;}
.p-feats li{display:flex;align-items:center;gap:11px;font-size:14px;color:var(--text);font-weight:500;}
.p-check{width:21px;height:21px;border-radius:50%;background:var(--blue);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.p-check svg{width:11px;height:11px;}
.p-cta-btn{display:block;text-align:center;margin-top:28px;padding:15px;border-radius:10px;font-size:15px;font-weight:700;color:white;background:#25d366;text-decoration:none;font-family:'Sora',sans-serif;transition:all .2s;box-shadow:0 4px 18px rgba(37,211,102,.3);}
.p-cta-btn:hover{background:#1ebe5d;transform:translateY(-2px);}
.neg-grid{display:flex;gap:12px;flex-wrap:wrap;justify-content:center;margin-top:46px;}
.neg-pill{display:flex;align-items:center;gap:9px;background:white;border:1.5px solid var(--border);border-radius:100px;padding:10px 20px;font-size:13px;font-weight:600;color:var(--text);transition:all .2s;}
.neg-pill:hover{border-color:var(--blue);color:var(--blue);transform:translateY(-2px);}
.cta-final{padding:96px 6%;text-align:center;background:var(--dark);position:relative;overflow:hidden;}
.cta-final::before{content:'';position:absolute;top:-300px;left:50%;transform:translateX(-50%);width:800px;height:800px;background:radial-gradient(circle,rgba(37,99,235,.14) 0%,transparent 70%);pointer-events:none;}
.cta-final h2{font-size:clamp(30px,5vw,52px);font-weight:800;color:white;letter-spacing:-2px;margin-bottom:14px;position:relative;}
.cta-final p{font-size:17px;color:rgba(255,255,255,.55);margin-bottom:38px;position:relative;}
.cta-wa{display:inline-flex;align-items:center;gap:10px;padding:16px 40px;border-radius:12px;font-size:16px;font-weight:700;color:white;background:#25d366;border:none;cursor:pointer;text-decoration:none;transition:all .25s;font-family:'Sora',sans-serif;box-shadow:0 6px 24px rgba(37,211,102,.38);position:relative;}
.cta-wa:hover{background:#1ebe5d;transform:translateY(-3px);box-shadow:0 10px 32px rgba(37,211,102,.45);}
footer{padding:36px 6%;background:#0f172a;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;}
.f-logo{display:flex;align-items:center;gap:9px;text-decoration:none;}
.f-logo-icon{width:27px;height:27px;background:var(--blue);border-radius:7px;display:flex;align-items:center;justify-content:center;}
.f-logo-text{font-size:15px;font-weight:700;color:white;}
.f-copy{font-size:13px;color:rgba(255,255,255,.3);}
.f-links{display:flex;gap:20px;}
.f-links a{font-size:13px;color:rgba(255,255,255,.35);text-decoration:none;transition:color .2s;}
.f-links a:hover{color:white;}
@keyframes fadeUp{from{opacity:0;transform:translateY(22px);}to{opacity:1;transform:translateY(0);}}
.reveal{opacity:0;transform:translateY(26px);transition:opacity .55s ease,transform .55s ease;}
.reveal.visible{opacity:1;transform:translateY(0);}
@media(max-width:900px){.preview-body{grid-template-columns:1fr;}.p-sidebar{display:none;}.steps{grid-template-columns:1fr 1fr;gap:32px;}.steps::before{display:none;}}
@media(max-width:640px){.nav-links{display:none;}.steps{grid-template-columns:1fr;}.p-head{flex-direction:column;gap:14px;}footer{flex-direction:column;text-align:center;}}
</style>
</head>
